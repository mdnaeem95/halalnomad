{
  "expo": {
    "name": "HalalNomad",
    "slug": "halalnomad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "halalnomad",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.halalnomad.app",
      "config": {
        "googleMapsApiKey": "AIzaSyDytPqAN0RbRt3_jytvLLdIiODyN8dJXCM"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HalalNomad needs your location to show Halal places near you.",
        "NSCameraUsageDescription": "HalalNomad needs camera access to take photos of Halal places and certificates.",
        "NSPhotoLibraryUsageDescription": "HalalNomad needs photo library access to upload photos of Halal places.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.halalnomad.app",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDytPqAN0RbRt3_jytvLLdIiODyN8dJXCM"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B5E20",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "naeem-th",
          "project": "halal"
        }
      ],
      "expo-secure-store",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b620a98-9485-415d-bbe2-2397e7ab1ed9"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8b620a98-9485-415d-bbe2-2397e7ab1ed9"
    }
  }
}
