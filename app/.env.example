# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry (optional — crash reporting disabled if not set)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog (optional — analytics disabled if not set)
EXPO_PUBLIC_POSTHOG_API_KEY=

# RevenueCat (optional — subscriptions disabled if not set)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google Maps API keys are set in app.json under ios.config and android.config
