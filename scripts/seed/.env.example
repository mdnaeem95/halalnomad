# Copy to .env and fill in. Never commit .env.

# Supabase — service role key, NOT the anon key. The seed pipeline writes
# to places_staging which has RLS lock-down; only service role can touch it.
SUPABASE_URL=https://aytvorjaetitthzuijkv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Google Places API — enable "Places API" in your Google Cloud project.
# Same project as the Maps API key in app.json. ~$17 per 1k Text Search
# requests; full tier-1 city sweep is well under $50.
GOOGLE_PLACES_API_KEY=

# UUID of the user who'll be marked as `added_by` for promoted places.
# Use a service/system account, not a real user. Create in Supabase if
# needed; can be the demo reviewer account UUID for now.
SEED_USER_ID=
